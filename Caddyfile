# Caddyfile pro produkci na VPS.
# Proměnné substituované v čase adaptace: {$VAR_NAME}
# (Caddy 2 syntaxe, viz https://caddyserver.com/docs/caddyfile/concepts#environment-variables)

{
    email {$CADDY_EMAIL}
    admin localhost:2019
}

{$CADDY_DOMAIN} {
    encode zstd gzip

    # BasicAuth — bcrypt hash v env (escape $ → $$ v .env kvůli docker-compose)
    basic_auth {
        {$CADDY_BASIC_AUTH_USER} {$CADDY_BASIC_AUTH_HASH}
    }

    # API backend (REST + WebSocket)
    handle /api/* {
        reverse_proxy asistent-backend:8000
    }

    # SearXNG self-hosted search
    handle /searxng/* {
        uri strip_prefix /searxng
        reverse_proxy asistent-searxng:8080
    }

    # Frontend (Next.js)
    handle {
        reverse_proxy asistent-frontend:3000
    }

    # Security headers
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "geolocation=(), microphone=(), camera=()"
        -Server
    }

    log {
        output file /var/log/caddy/access.log {
            roll_size 10mb
            roll_keep 5
        }
        format json
    }
}
