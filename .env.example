# ==========================================
# Realitní Asistent — konfigurace prostředí
# Zkopíruj jako `.env` a vyplň skutečné hodnoty.
# NIKDY necommitovat `.env` do gitu (.gitignore to hlídá).
# ==========================================

# ----- Aplikace -----
APP_ENV=development                     # development | production
APP_TIMEZONE=Europe/Prague
APP_BASE_URL=http://localhost:3000      # URL, na které běží frontend

# ----- Backend -----
BACKEND_PORT=8000
BACKEND_LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR
BACKEND_SECRET_KEY=change-me-to-random-string-min-32-chars
BACKEND_CORS_ORIGINS=http://localhost:3000,https://asistent.reality-pittner.cz

# ----- Databáze -----
DATABASE_URL=sqlite:///./data/app.db
CHROMA_PERSIST_DIR=./data/chroma

# ----- AI / Claude -----
# Claude Code CLI musí být nainstalovaný na hostovi a přihlášený
# (claude login → Claude Max account).
# Cesta ke claude binárce (v Dockeru se mountuje z hosta):
CLAUDE_CLI_PATH=/usr/bin/claude
# Session timeout pro SDK (sekundy)
CLAUDE_SESSION_TIMEOUT=300
# Max tokens pro odpověď
CLAUDE_MAX_TOKENS=8192

# ----- Embedding model -----
# Který embedding model použít pro RAG.
# Doporučeno: intfloat/multilingual-e5-small (~130 MB, dobré pro CZ)
# Alternativy: intfloat/multilingual-e5-base (~280 MB, lepší kvalita)
EMBEDDING_MODEL=intfloat/multilingual-e5-small
EMBEDDING_DEVICE=cpu                    # cpu | cuda (na VPS cpu)

# ----- Whisper (Skill 2 — Transkripce) -----
# Velikost modelu. Small (244 MB) je default pro CX23 (4 GB RAM).
# Možnosti: tiny | base | small | medium | large-v3
WHISPER_MODEL=small
WHISPER_DEVICE=cpu                      # cpu | cuda
WHISPER_COMPUTE_TYPE=int8               # int8 | float16 | float32

# ----- Google OAuth (Calendar + Drive) -----
# Buď reusovat OAuth z pluginu ceske-realitni-pravo (doporučeno),
# nebo vlastní client credentials:
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://asistent-vps.tail46e4c2.ts.net/api/auth/google/callback
# Scopes (čárkou oddělené). gmail.modify = čtení + odesílání + labels (bez trvalého smazání).
GOOGLE_SCOPES=https://www.googleapis.com/auth/calendar,https://www.googleapis.com/auth/drive.file,https://www.googleapis.com/auth/gmail.modify
# E-mail používaný pro OAuth:
GOOGLE_ACCOUNT_EMAIL=adam.hoffik@gmail.com

# ----- Google Drive složka -----
GDRIVE_ROOT_FOLDER=Realitní asistent

# ----- SearXNG (self-hosted web search) -----
SEARXNG_URL=http://searxng:8080
SEARXNG_SECRET=change-me-to-random-string
SEARXNG_RESULT_LIMIT=10

# ----- Weather (Open-Meteo, žádný klíč) -----
WEATHER_LAT=50.6167
WEATHER_LON=14.5667
WEATHER_LOCATION_NAME=Zahrádky

# ----- Scheduler (APScheduler) -----
SCHEDULER_TIMEZONE=Europe/Prague
BRIEFING_CRON_HOUR=7
BRIEFING_CRON_MINUTE=0
NEWS_SCRAPE_INTERVAL_MINUTES=120
CALENDAR_SYNC_INTERVAL_MINUTES=15

# ----- Šifrování klientských PII polí -----
# 32 bajtů base64 (generuj: python -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())")
PII_ENCRYPTION_KEY=

# ----- Caddy + BasicAuth (jen produkce) -----
# Bcrypt hash hesla. Generuj příkazem:
#   docker run --rm caddy:2.8-alpine caddy hash-password --plaintext "TvojeNoveHeslo"
# V .env hodnotu musí mít $ zdvojené ($$), kvůli docker-compose interpolaci.
CADDY_BASIC_AUTH_USER=adam
CADDY_BASIC_AUTH_HASH=
CADDY_EMAIL=adam.hoffik@gmail.com

# Tailnet hostname (Tailscale HTTPS — aplikace dostupná JEN přes VPN)
# Získáš z `tailscale status --json | grep MagicDNS` + hostname VPS
TAILSCALE_HOSTNAME=asistent-vps.tail46e4c2.ts.net

# (Legacy — nepoužíváme, aplikace je tailnet-only)
# CADDY_DOMAIN=asistent.46-225-58-232.nip.io

# ----- Frontend (Next.js) -----
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8000
NEXT_PUBLIC_APP_NAME=Realitní Asistent
